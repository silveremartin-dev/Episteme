<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.jscience.benchmarks.ui.MainController"
            stylesheets="@benchmarking.css" styleClass="root-pane">
    
    <top>
        <HBox styleClass="header-bar" alignment="CENTER_LEFT" spacing="20">
            <padding><Insets top="15" right="20" bottom="15" left="20"/></padding>
            <Label fx:id="mainTitleLabel" text="JSCIENCE BENCHMARKING" styleClass="header-title"/>
            <Region HBox.hgrow="ALWAYS" />
            <Label fx:id="languageLabel" text="Language:" styleClass="header-label"/>
            <ComboBox fx:id="languageSelector" promptText="Language" styleClass="combo-box-primary" />
            <!-- Settings button removed as per user request -->
            <Button fx:id="aboutBtn" text="ABOUT" onAction="#handleAbout" styleClass="action-button-primary" />
        </HBox>
    </top>

    <center>
        <TabPane fx:id="mainTabPane" side="LEFT" tabClosingPolicy="UNAVAILABLE" styleClass="main-tab-pane">
            
            <!-- Tab 1: Execution Control -->
            <Tab fx:id="executionTab" text="EXECUTION">
                <graphic>
                    <ImageView fitHeight="18" fitWidth="18" preserveRatio="true">
                        <image>
                            <javafx.scene.image.Image url="@execution_icon.png" />
                        </image>
                    </ImageView>
                </graphic>

                <VBox spacing="10">
                    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label fx:id="benchmarkSelectionLabel" text="Benchmark Selection" styleClass="section-title"/>
                        <Region HBox.hgrow="ALWAYS" />
                        <Button fx:id="runSelectedBtn" text="RUN SELECTED" onAction="#handleRunSelected" styleClass="action-button-primary" />
                        <Button fx:id="runAllBtn" text="RUN ALL" onAction="#handleRunAll" styleClass="action-button-primary" />
                        <Button fx:id="stopBtn" text="STOP" onAction="#handleStop" styleClass="action-button-danger" />
                    </HBox>
                    
                    <TreeTableView fx:id="benchmarkTreeTable" VBox.vgrow="ALWAYS" styleClass="benchmark-tree">
                        <columns>
                            <TreeTableColumn fx:id="nameColumn" text="Name" prefWidth="250" />
                            <TreeTableColumn fx:id="backendColumn" text="Backend" prefWidth="80" />
                            <TreeTableColumn fx:id="libraryColumn" text="Library" prefWidth="120" />
                            <TreeTableColumn fx:id="providerColumn" text="Algorithm Provider" prefWidth="150" />
                            <TreeTableColumn fx:id="descriptionColumn" text="Description" prefWidth="350" />
                            <TreeTableColumn fx:id="statusColumn" text="Status" prefWidth="90" />
                            <TreeTableColumn fx:id="resultColumn" text="Last Result" prefWidth="200" />
                        </columns>
                        <columnResizePolicy>
                            <TreeTableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                        </columnResizePolicy>
                    </TreeTableView>
                </VBox>
            </Tab>

            <!-- Tab 2: Visualization -->
            <Tab fx:id="visualizationTab" text="VISUALIZATION">
                <graphic>
                    <ImageView fitHeight="18" fitWidth="18" preserveRatio="true">
                        <image>
                            <javafx.scene.image.Image url="@visualization_icon.png" />
                        </image>
                    </ImageView>
                </graphic>

                <VBox spacing="20">
                    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                    <HBox spacing="20" alignment="CENTER_LEFT">
                        <Label fx:id="analyticsLabel" text="Performance Analytics" styleClass="section-title"/>
                        <Region HBox.hgrow="ALWAYS" />
                        <ComboBox fx:id="metricSelector" promptText="Select Metric" styleClass="combo-box-primary" />
                        <Button fx:id="exportChartBtn" text="EXPORT CHART" onAction="#handleExportChart" styleClass="action-button-primary" />
                    </HBox>
                    
                    <AnchorPane VBox.vgrow="ALWAYS">
                        <TabPane fx:id="visualizationTabPane" side="TOP" tabClosingPolicy="UNAVAILABLE" 
                                 AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0" 
                                 AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" />
                    </AnchorPane>
                </VBox>
            </Tab>

            <!-- Tab 3: Environment -->
            <Tab fx:id="environmentTab" text="ENVIRONMENT" styleClass="tab">
                <graphic>
                    <ImageView fitHeight="18" fitWidth="18" preserveRatio="true">
                        <image>
                            <javafx.scene.image.Image url="@environment_icon.png" />
                        </image>
                    </ImageView>
                </graphic>

                <fx:include fx:id="environmentView" source="EnvironmentView.fxml"/>
            </Tab>

            <!-- Tab 4: History & Reports -->
            <Tab fx:id="historyTab" text="HISTORY">
                <graphic>
                    <ImageView fitHeight="18" fitWidth="18" preserveRatio="true">
                        <image>
                            <javafx.scene.image.Image url="@history_icon.png" />
                        </image>
                    </ImageView>
                </graphic>

                <VBox spacing="10">
                    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label fx:id="historyTitleLabel" text="Historical Runs" styleClass="section-title"/>
                        <Region HBox.hgrow="ALWAYS" />
                        <Button fx:id="exportHistoryBtn" text="EXPORT JSON" onAction="#handleExportHistoryJson" styleClass="action-button-primary" />
                    </HBox>
                    <TableView fx:id="historyTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="dateColumn" text="Date" prefWidth="150" />
                            <TableColumn fx:id="histNameColumn" text="Name" prefWidth="200" />
                            <TableColumn fx:id="histBackendColumn" text="Backend" prefWidth="80" />
                            <TableColumn fx:id="histLibraryColumn" text="Library" prefWidth="120" />
                            <TableColumn fx:id="histProviderColumn" text="Provider" prefWidth="150" />
                            <TableColumn fx:id="histDomainColumn" text="Domain" prefWidth="120" />
                            <TableColumn fx:id="resultsColumn" text="Result" prefWidth="200" />
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                        </columnResizePolicy>
                    </TableView>
                </VBox>
            </Tab>

        </TabPane>
    </center>

    <bottom>
        <HBox styleClass="status-bar" alignment="CENTER_LEFT" spacing="15">
            <padding><Insets top="5" right="15" bottom="5" left="15"/></padding>
            <ProgressBar fx:id="globalProgressBar" progress="0.0" prefWidth="250" />
            <Label fx:id="statusBarLabel" text="Ready" styleClass="status-text"/>
            <Region HBox.hgrow="ALWAYS" />
            <Label fx:id="versionLabel" text="JScience Benchmarking v1.0" styleClass="version-text"/>
        </HBox>
    </bottom>

</BorderPane>
