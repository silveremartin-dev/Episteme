  <profiles>
    <profile>
      <id>macos-arm64-classifier</id>
      <activation>
        <os>
          <family>mac</family>
          <arch>aarch64</arch>
        </os>
      </activation>
      <properties>
        <javacpp.platform>macosx-arm64</javacpp.platform>
      </properties>
    </profile>
    <profile>
      <id>macos-x86_64-classifier</id>
      <activation>
        <os>
          <family>mac</family>
          <arch>x86_64</arch>
        </os>
      </activation>
      <properties>
        <javacpp.platform>macosx-x86_64</javacpp.platform>
      </properties>
    </profile>
    <profile>
      <id>m2e-ide-classifier-fallback</id>
      <activation>
        <property>
          <name>m2e.version</name>
        </property>
      </activation>
      <properties>
        <os.detected.classifier>windows-x86_64</os.detected.classifier>
      </properties>
    </profile>
    <profile>
      <id>legacy</id>
      <activation>
        <activeByDefault>true</activeByDefault>
      </activation>
      <properties>
        <maven.compiler.release>25</maven.compiler.release>
      </properties>
      <build>
        <plugins>
          <plugin>
            <groupId>org.apache.maven.plugins</groupId>
            <artifactId>maven-compiler-plugin</artifactId>
            <configuration>
              <release>25</release>
              <compilerArgs>
                <arg>--add-modules</arg>
                <arg>jdk.incubator.vector</arg>
                <arg>-Xpkginfo:always</arg>
              </compilerArgs>
              <testExcludes>
                <exclude>module-info.java</exclude>
              </testExcludes>
              <excludes>
                <exclude>module-info.java</exclude>
              </excludes>
            </configuration>
          </plugin>
        </plugins>
      </build>
    </profile>
    <profile>
      <id>jpms</id>
      <properties>
        <maven.compiler.release>25</maven.compiler.release>
      </properties>
      <build>
        <plugins>
          <plugin>
            <groupId>org.apache.maven.plugins</groupId>
            <artifactId>maven-compiler-plugin</artifactId>
            <configuration>
              <!-- Enforce module-path for Java 25 -->
            </configuration>
          </plugin>
        </plugins>
      </build>
    </profile>
    <profile>
      <id>ui-desktop</id>
      <activation>
        <activeByDefault>true</activeByDefault>
      </activation>
    </profile>
  </profiles>
</project>
