<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>
  <groupId>org.episteme</groupId>
  <artifactId>episteme-parent</artifactId>
  <version>1.0.0-beta1</version>
  <packaging>pom</packaging>
  <name>Episteme Unifying Parent</name>
  <description>Episteme - Unified Scientific Computing Framework (Parent POM)</description>
  <url>https://github.com/silveremartin-dev/Episteme</url>
  <inceptionYear>2025</inceptionYear>
  <modules>
    <module>episteme-core</module>
    <module>episteme-natural</module>
    <module>episteme-social</module>
    <module>episteme-native</module>
    <module>episteme-benchmarks</module>
    <module>episteme-resources</module>
    <module>episteme-featured-apps</module>
    <module>episteme-server</module>
    <module>episteme-worker</module>
    <module>episteme-client</module>
    <module>episteme-database</module>
    <module>episteme-jni</module>
  </modules>
  <licenses>
    <license>
      <name>MIT License</name>
      <url>https://opensource.org/licenses/MIT</url>
      <distribution>repo</distribution>
    </license>
  </licenses>
  <distributionManagement>
    <repository>
      <id>github</id>
      <name>GitHub Packages</name>
      <url>https://maven.pkg.github.com/silveremartin-dev/Episteme</url>
    </repository>
  </distributionManagement>
  <developers>
    <developer>
      <id>silvere</id>
      <name>Silvere Martin-Michiellot</name>
      <email>silvere.martin@gmail.com</email>
      <roles>
        <role>Lead Architect</role>
        <role>Original Author</role>
      </roles>
    </developer>
    <developer>
      <id>gemini</id>
      <name>Gemini AI (Google DeepMind)</name>
      <roles>
        <role>Implementation</role>
        <role>Architecture Design</role>
      </roles>
    </developer>
  </developers>
  <properties>
    <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
    <maven.compiler.release>25</maven.compiler.release>
    <!-- JSR-385 Units of Measurement -->
    <uom.version>2.2</uom.version>
    <indriya.version>2.2</indriya.version>
    <!-- Logging -->
    <slf4j.version>2.0.9</slf4j.version>
    <logback.version>1.4.11</logback.version>
    <!-- Testing -->
    <junit.version>5.10.1</junit.version>
    <assertj.version>3.25.1</assertj.version>
    <!-- Web/JSON -->
    <javalin.version>6.1.3</javalin.version>
    <jackson.version>2.16.1</jackson.version>
    <!-- GPU/Performance -->
    <jcuda.version>11.8.0</jcuda.version>
    <!-- UI (JavaFX) -->
    <javafx.version>21.0.1</javafx.version>
    <mockito.version>5.11.0</mockito.version>
    <resilience4j.version>2.2.0</resilience4j.version>
    <onnxruntime.version>1.17.1</onnxruntime.version>
    <nd4j.version>1.0.0-M2.1</nd4j.version>
    <arrow.version>6.0.1-1.5.8</arrow.version>
    <ode4j.version>0.5.4</ode4j.version>
    <auto-service.version>1.1.1</auto-service.version>
    <jmh.version>1.37</jmh.version>
    <!-- Native Libraries -->
    <javacpp.version>1.5.10</javacpp.version>
    <javacv.version>1.5.10</javacv.version>
    <opencv.version>4.9.0-1.5.10</opencv.version>
    <openblas.version>0.3.26-${javacpp.version}</openblas.version>
    <hdf5.version>1.14.3-1.5.10</hdf5.version>
    
    <!-- Platform targeting to avoid downloading all binaries (e.g. Windows DLLs in Docker) -->
    <javacpp.platform>${os.detected.classifier}</javacpp.platform>
    
    <maven.compiler.args>--add-modules=jdk.incubator.vector -Xpkginfo:always</maven.compiler.args>
    <argLine></argLine>
  </properties>
